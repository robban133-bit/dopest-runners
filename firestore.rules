// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // Admin check via custom claim set by seed-admin.ts
    function isAdmin() {
      return isAuthed() && request.auth.token.isAdmin == true;
    }

    // Fields that must never be changed by clients
    function noPrivilegeEscalation() {
      return !request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(['isAdmin', 'uid', 'createdAt', 'totalAttendance', 'yearAttendance', 'streak']);
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Anyone authenticated can read their own profile; admins can read all
      allow read: if isOwner(uid) || isAdmin();

      // Create: only the user themselves, and only for their own uid
      allow create: if isOwner(uid)
        && request.resource.data.isAdmin == false   // can't self-promote
        && request.resource.data.uid == uid;

      // Update: only the owner, and can't touch protected fields
      allow update: if isOwner(uid) && noPrivilegeEscalation();

      // Admins can update (for seeding and corrections)
      allow update: if isAdmin();

      allow delete: if false; // never delete users from client
    }

    // ── Sessions ──────────────────────────────────────────────────────────────

    match /sessions/{sessionId} {
      // Any authenticated user can read sessions (for check-in page)
      allow read: if isAuthed();

      // Only the API (via Admin SDK) creates/updates sessions
      // We enforce this by not granting client write access at all —
      // all mutations go through /api/session which uses the Admin SDK
      allow create, update, delete: if false;
    }

    // ── Check-ins ─────────────────────────────────────────────────────────────

    match /checkins/{checkinId} {
      // Users can read their own check-ins; admins read all
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      // No client writes — all check-in mutations go through /api/checkin
      allow create, update, delete: if false;
    }

    // ── Catch-all: deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
